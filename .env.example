# Copy this file to .env and fill in values.
# .env is gitignored — never commit it.

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
# Channel where the weekly digest is posted
SLACK_DIGEST_CHANNEL=#team-digest

# ─── Survey ───────────────────────────────────────────────────────────────────
# Path to local survey response file (Phase 2 — file-based input)
SURVEY_DATA_PATH=./data/survey.json

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info   # debug | info | warn | error
