# Copy this file to .env.local and fill in your real credentials.
# .env.local is gitignored — never commit it.
# Values here override .env.

# ─── Azure OpenAI ────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_DEPLOYMENT_DEFAULT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ─── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# ─── Optional personal overrides ──────────────────────────────────────────────
# LOG_LEVEL=debug
# SLACK_DIGEST_CHANNEL=#test-digest   # point to a test channel while developing
