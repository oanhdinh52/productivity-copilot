{
  "name": "productivity-copilot",
  "version": "1.0.0",
  "description": "AI agent that transforms the weekly Friday employee survey into an active intelligence layer for LeapXpert.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "node --check src/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "keywords": ["ai", "productivity", "survey", "nlp", "slack"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "jest": "^29.0.0"
  },
  "jest": {
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80,
        "branches": 80,
        "statements": 80
      }
    },
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
